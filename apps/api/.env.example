# --- Core ---------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
BRAND_NAME=Xavfsizmi

# --- Database / cache ---------------------------------------------------
DATABASE_URL=postgresql+asyncpg://xavfsizmi:xavfsizmi_dev@localhost:5432/xavfsizmi
REDIS_URL=redis://localhost:6379/0

# --- HIBP --------------------------------------------------------------
HIBP_API_KEY=
HIBP_BASE_URL=https://haveibeenpwned.com/api/v3
HIBP_USER_AGENT=xavfsizmi/0.1 (+https://xavfsizmi.example)

# --- Turnstile ---------------------------------------------------------
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- SMTP --------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Xavfsizmi <noreply@xavfsizmi.example>
SMTP_TLS=false

# --- Stripe ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Security ----------------------------------------------------------
SESSION_SECRET=please-change-me-in-production
ALLOWED_ORIGINS=http://localhost:5173
ADMIN_EMAILS=

# --- Rate limits (per minute) -----------------------------------------
RL_LOOKUP_PER_IP=20
RL_API_FREE=10
RL_API_PRO=100
RL_API_HIGH_RPM=600
