{
  "name": "xavfsizmi",
  "version": "0.1.0",
  "private": true,
  "description": "Multilingual breach-lookup service inspired by HIBP",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "translate": "tsx scripts/translate.ts",
    "api:lint": "cd apps/api && uv run ruff check .",
    "api:format": "cd apps/api && uv run ruff format .",
    "api:typecheck": "cd apps/api && uv run mypy src",
    "api:test": "cd apps/api && uv run pytest"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
