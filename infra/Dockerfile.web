# syntax=docker/dockerfile:1.7
#
# Multi-stage production image for the Xavfsizmi web SPA.
#
# Stage 1 (deps):    install the pnpm workspace dependencies only.
# Stage 2 (build):   copy source and build with Vite.
# Stage 3 (runtime): nginx 1.27-alpine serving the built `dist` directory
#                    on port 8080 with sane caching and SPA fallback.
#
# Build context MUST be the repo root.
#
# Build args:
#   VITE_API_BASE_URL          API base URL embedded into the bundle
#   VITE_PASSWORDS_BASE_URL    Cloudflare Worker URL for k-anonymity lookups
#   VITE_TURNSTILE_SITE_KEY    Public Turnstile site key
#   VITE_BRAND_NAME            Brand name (defaults to "Xavfsizmi")

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
FROM node:22-alpine AS deps

WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@9.15.1 --activate

# Copy lockfile + workspace manifests separately so the install layer caches
# whenever no package.json changes.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/i18n-data/package.json ./packages/i18n-data/
COPY packages/eslint-config/package.json ./packages/eslint-config/

RUN pnpm install --frozen-lockfile

# -----------------------------------------------------------------------------
# Build
# -----------------------------------------------------------------------------
FROM node:22-alpine AS build

ARG VITE_API_BASE_URL=http://localhost:8000
ARG VITE_PASSWORDS_BASE_URL=http://localhost:8787
ARG VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
ARG VITE_BRAND_NAME=Xavfsizmi

ENV VITE_API_BASE_URL=${VITE_API_BASE_URL} \
    VITE_PASSWORDS_BASE_URL=${VITE_PASSWORDS_BASE_URL} \
    VITE_TURNSTILE_SITE_KEY=${VITE_TURNSTILE_SITE_KEY} \
    VITE_BRAND_NAME=${VITE_BRAND_NAME}

WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@9.15.1 --activate

# Pull the entire workspace's resolved dependency graph from the deps stage.
# pnpm hoists most deps into /repo/node_modules but every workspace package
# has its own node_modules of symlinks too, so we have to bring them all.
COPY --from=deps /repo/node_modules ./node_modules
COPY --from=deps /repo/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /repo/packages/shared-types/node_modules ./packages/shared-types/node_modules
COPY --from=deps /repo/packages/i18n-data/node_modules ./packages/i18n-data/node_modules
COPY --from=deps /repo/packages/eslint-config/node_modules ./packages/eslint-config/node_modules

COPY . .

RUN pnpm --filter @xavfsizmi/web build

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
FROM nginx:1.27-alpine AS runtime

# Run nginx as the unprivileged `nginx` user that ships with the base image.
COPY --from=build /repo/apps/web/dist /usr/share/nginx/html
COPY infra/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:8080/ || exit 1
